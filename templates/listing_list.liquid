{% layout "base.liquid" %}
{% from 'helper' import renderBreadcrumbs %}

<header class="page-header">
  <h1>Listings</h1>
</header>

{{ renderBreadcrumbs(Breadcrumbs, "breadcrumbs-attached") }}

<ul class="list-unstyled">
  {% for entry in Entries %}
  <li><a href="{{ entry.Url }}"><i class="bi {% if entry.IsItem %}bi-file-earmark-code-fill{% else %}bi-folder-fill{% endif %}"></i> {{ entry.LastPart }}</a>
  {% endfor %}
</ul>
