{% layout "base.liquid" %}
{% from 'helper' import renderBreadcrumbs %}

<header class="page-header">
  <h1>{{ title }}
  <a class="header-extra" href="{{ item | listingSourceUrl }}">(Source)</a>
  </h1>
</header>

{{ renderBreadcrumbs(Breadcrumbs, "breadcrumbs-attached") }}

<div class="content-listing">
{{ Item.Content | raw }}
</div>
