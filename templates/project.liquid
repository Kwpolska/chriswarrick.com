{% layout "base.liquid" %}

<header class="page-header">
<h1>
  <span class="header-breadcrumb"><a href="/projects/">Projects</a></span>
  {{ Title }}
  </h1>
</header>

<p class="lead">{{ Item.Meta.Description }}</p>

{% if Item.Meta.Project.Logo %}
<div class="d-flex">
  <div class="flex-grow-1 me-3">
    {% endif %}
    <div class="card project-card border-primary">
      <div class="card-header bg-primary"><h3><i class="bi bi-info-circle"></i><span class="project-header-details">Details</span></h3></div>

      <table class="table table-hover">
        <tr>
          <td><b>Status</b></td>
          <td>{{ Item.Meta.Project.DevStatus | projectDevStatus }}</td>
        </tr>

        {% if Item.Meta.Project.Language %}
          <tr>
            <th>Language</th>
            <td>{{ Item.Meta.Project.Language }}</td>
          </tr>
        {% endif %}

        {% if Item.Meta.Project.License %}
          <tr>
            <th>License</th>
            <td>{{ Item.Meta.Project.License }}</td>
          </tr>
        {% endif %}

        {% if Item.Meta.Project.Role %}
          <tr>
            <th>Role</th>
            <td>{{ Item.Meta.Project.Role }}</td>
          </tr>
        {% endif %}

      </table>
      {% if Item.Meta.Project.Link or Item.Meta.Project.Download or Item.Meta.Project.GitHub or Item.Meta.Project.BugTracker %}
        <div class="card-footer">
          {% if Item.Meta.Project.link %}
            <a href="{{ Item.Meta.Project.link }}" class="btn btn-lg btn-primary"><i class="bi bi-link"></i> Website</a>
          {% endif %}
          {% if Item.Meta.Project.Download == true and Item.Meta.Project.Link == false %}
            <a href="{{ Item.Meta.Project.Download }}" class="btn btn-lg btn-primary"><i class="bi bi-download"></i> Download</a>
            {% elsif Item.Meta.Project.Download %}
            <a href="{{ Item.Meta.Project.Download }}" class="btn btn-lg btn-success"><i class="bi bi-download"></i> Download</a>
          {% endif %}
          {% if Item.Meta.Project.GitHub %}
            <a href="{{ Item.Meta.Project.GitHub }}" class="btn btn-lg btn-info"><i class="bi bi-github"></i> GitHub</a>
          {% endif %}
          {% if Item.Meta.Project.Gallery %}
            <a href="{{ Item.Meta.Project.Gallery }}" class="btn btn-lg btn-success"><i class="bi bi-image"></i> Gallery</a>
          {% endif %}
          {% if Item.Meta.Project.BugTracker %}
            <a href="{{ Item.Meta.Project.BugTracker }}" class="btn btn-lg btn-danger"><i class="bi bi-bug"></i> Bug Tracker</a>
          {% endif %}
        </div>
      {% endif %}
    </div>
    {% if Item.Meta.Project.Logo %}
  </div>
  <div class="flex-shrink-0">
    <img src="{{ Item.Meta.Project.Logo }}" alt="{{ Title }}">
  </div>
</div>
{% endif %}

  {{ Item.Content | raw }}
